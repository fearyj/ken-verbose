---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="ken --verbose">
  <section class="hero">
    <div class="terminal-heading">
      <span class="prompt">$</span> whoami
    </div>
    <h1>Hey, I'm <span class="highlight">Ken</span></h1>
    <p class="intro">
      Welcome to my corner of the internet. I'm a developer who loves building
      things, breaking things, and writing about it along the way.
    </p>
    <p class="intro">
      This is where I share my projects, experiences, and the occasional deep
      dive into topics that interest me.
    </p>

    <div class="links">
      <a href={`${import.meta.env.BASE_URL}/experience/`} class="btn">
        → experience
      </a>
      <a href={`${import.meta.env.BASE_URL}/blog/`} class="btn btn-outline">
        → blog
      </a>
    </div>
  </section>

  <section class="about">
    <div class="terminal-heading">
      <span class="prompt">$</span> cat about.txt
    </div>
    <div class="card">
      <h3>What I Do</h3>
      <p>
        I build software, explore new technologies, and document my journey. From
        full-stack web apps to systems programming — if it's interesting, I'm
        probably tinkering with it.
      </p>
      <div class="tags">
        <span class="tag">TypeScript</span>
        <span class="tag">Python</span>
        <span class="tag">React</span>
        <span class="tag">Node.js</span>
        <span class="tag">Cloud</span>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 2rem 0 3rem;
  }

  .highlight {
    color: var(--accent);
  }

  .intro {
    font-size: 1.1rem;
    max-width: 600px;
  }

  .links {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .btn {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    padding: 0.6rem 1.2rem;
    border-radius: 6px;
    background: var(--accent);
    color: var(--bg);
    font-weight: 600;
    transition: background 0.2s;
  }

  .btn:hover {
    background: var(--accent-hover);
    color: var(--bg);
  }

  .btn-outline {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text);
  }

  .btn-outline:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: transparent;
  }

  .about {
    padding: 2rem 0;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }
</style>
