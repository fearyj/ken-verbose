---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="ken --verbose">
  <section class="hero">
    <div class="terminal-heading">
      <span class="prompt">$</span> whoami
    </div>
    <h1>Hey, I'm <span class="highlight">Ken</span></h1>
    <p class="intro">
      I work at the intersection of high-performance computing, cybersecurity,
      and software development. From running simulations on GPU clusters to
      hardening infrastructure and building tools — I like solving hard problems
      across the stack.
    </p>
    <p class="intro">
      This is where I document what I'm working on, what I've learned, and
      the occasional deep dive into things that interest me.
    </p>

    <div class="links">
      <a href={`${import.meta.env.BASE_URL}/experience/`} class="btn">
        → experience
      </a>
      <a href={`${import.meta.env.BASE_URL}/blog/`} class="btn btn-outline">
        → blog
      </a>
    </div>
  </section>

  <section class="about">
    <div class="terminal-heading">
      <span class="prompt">$</span> cat about.txt
    </div>
    <div class="card">
      <h3>What I Do</h3>
      <p>
        I've worked on large-scale supercomputing clusters (NSCC Singapore, NTU HPC),
        profiled and optimized scientific workflows, built security tooling, and
        fine-tuned LLMs on DGX systems. I enjoy going deep on whatever I'm working on.
      </p>
      <div class="tags">
        <span class="tag">HPC</span>
        <span class="tag">Python</span>
        <span class="tag">CUDA</span>
        <span class="tag">Cybersecurity</span>
        <span class="tag">MPI</span>
        <span class="tag">LLMs</span>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 2rem 0 3rem;
  }

  .highlight {
    color: var(--accent);
  }

  .intro {
    font-size: 1.1rem;
    max-width: 600px;
  }

  .links {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .btn {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    padding: 0.6rem 1.2rem;
    border-radius: 6px;
    background: var(--accent);
    color: var(--bg);
    font-weight: 600;
    transition: background 0.2s;
  }

  .btn:hover {
    background: var(--accent-hover);
    color: var(--bg);
  }

  .btn-outline {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text);
  }

  .btn-outline:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: transparent;
  }

  .about {
    padding: 2rem 0;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }
</style>
