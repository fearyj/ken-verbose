---
import BaseLayout from "../layouts/BaseLayout.astro";

const experiences = [
  {
    role: "HPC Research Assistant",
    company: "NTU Asian School of the Environment",
    period: "Mar 2026 — Present",
    description: [
      "Ran large-scale dynamic rupture simulations of the Mentawai seismic region on NVIDIA H100 GPU clusters to model downstream seismic impact on Singapore",
      "Performed CPU, GPU, and MPI profiling to benchmark and optimize PyQuake3D, identifying bottlenecks in large-scale parallel scientific workflows",
    ],
    tech: ["HPC", "CUDA", "MPI", "Python", "GPU Profiling"],
  },
  {
    role: "HPC Performance Engineer Intern",
    company: "National Supercomputing Centre (NSCC) Singapore",
    period: "Aug 2025 — Nov 2025",
    description: [
      "Benchmarked GROMACS molecular dynamics on A100/H100 GPU clusters for scalability and energy efficiency",
      "Profiled applications with NVIDIA Nsight Systems, Intel RAPL, Arm Forge, and IPM to identify bottlenecks across heterogeneous compute architectures",
      "Fine-tuned LLaMA 3.1 (8B/70B) using Megatron-LM on DGX H100 systems",
      "Built an agentic AI prototype with LangGraph to auto-validate PBS job scripts",
    ],
    tech: ["HPC", "GROMACS", "NVIDIA Nsight", "Megatron-LM", "LangGraph", "MPI"],
  },
  {
    role: "IT Trainee (Cybersecurity)",
    company: "ASE Singapore PTE LTD",
    period: "Jan 2025 - May 2025",
    description: [
      "Enhanced SIEM correlation rules and alerts to detect unauthorized access, privilege escalation, and data exfiltration across company infrastructure",
      "Conducted log analysis and forensic investigation to triage triggered alerts",
      "Performed penetration testing on internal servers to validate detection accuracy",
      "Led vulnerability patching across 60+ production devices to full compliance",
      "Authored the team's security incident response handbook",
    ],
    tech: ["SIEM", "Penetration Testing", "Log Analysis", "Vulnerability Management", "Incident Response"],
  },
  {
    role: "Developer Relations Intern",
    company: "Metaschool",
    period: "May 2024 - Jul 2024",
    description: [
      "Optimized blockchain education modules for Aptos, Sui, and Ethereum, achieving a 15% reduction in learner error rates",
      "Provided technical support to over 50 workshop participants, boosting course completion rates by 10%",
      "Collaborated with the marketing team to design targeted workshops, enhancing community engagement in Southeast Asia by 30%",
    ],
    tech: ["Blockchain", "Aptos", "Sui", "Ethereum", "Developer Education"],
  },
];
---

<BaseLayout title="Experience | ken --verbose">
  <section>
    <div class="terminal-heading">
      <span class="prompt">$</span> cat experience.log
    </div>
    <h1>Experience</h1>
    <p>Where I've worked and what I've built.</p>

    <div class="timeline">
      {
        experiences.map((exp) => (
          <div class="card exp-card">
            <div class="exp-header">
              <div>
                <h3>{exp.role}</h3>
                <p class="company">{exp.company}</p>
              </div>
              <span class="period">{exp.period}</span>
            </div>
            <ul class="description">
              {exp.description.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
            <div class="tags">
              {exp.tech.map((t) => (
                <span class="tag">{t}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 2rem;
  }

  .exp-card {
    position: relative;
  }

  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.75rem;
  }

  .company {
    color: var(--accent);
    font-size: 0.95rem;
    margin-bottom: 0;
  }

  .period {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .description {
    font-size: 0.95rem;
    padding-left: 1.2rem;
    margin-bottom: 0.5rem;
    color: var(--text-muted);
    list-style: disc;
  }

  .description li {
    margin-bottom: 0.4rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  @media (max-width: 640px) {
    .exp-header {
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>
